# Google GenAI / Gemini Developer API (Google AI Studio) Configuration
# Set to FALSE to use Gemini Developer API (recommended for rapid prototyping)
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GOOGLE_API_KEY=your_google_ai_studio_api_key_here

# Vertex AI (Google Cloud Platform) Configuration
# Uncomment and set these if GOOGLE_GENAI_USE_VERTEXAI is set to TRUE
# GOOGLE_GENAI_USE_VERTEXAI=TRUE
# VERTEX_PROJECT_ID=your-gcp-project-id
# VERTEX_LOCATION=us-central1
